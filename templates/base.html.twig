<!DOCTYPE html>
<html lang="{{ app.request.locale }}">
	<head>
		<meta charset="UTF-8">
		<meta name="viewport" content="width=device-width, initial-scale=1.0"> {% block title %}{% endblock %}
		<link rel="stylesheet" href="{{ asset('css/index.css') }}">

		<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
	</head>

	<body>

		<!-- Header -->
		{% include "Frontend/include/header.html.twig" %}

		<!-- navigation -->
		{% include "Frontend/include/navigation.html.twig" %}

		{% block body %}{% endblock %}


		<!-- footer -->
		{% include "Frontend/include/footer.html.twig" %}


		<script src="{{ asset('js/jquery-1.11.1.min.js') }}"></script>
		<script src="{{ asset('js/plugins.js') }}"></script>
		<script src="{{ asset('js/main.js') }}"></script>

		<!-- Bootstrap  -->
		<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
	</body>
</html>
