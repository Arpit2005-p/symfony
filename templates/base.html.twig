<!DOCTYPE html>
<html lang="{{ app.request.locale }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    {% block title %}{% endblock %}
    <link rel="stylesheet" href="{{ asset('css/index.css') }}">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@4.0.0/dist/css/bootstrap.min.css" integrity="sha384-Gn5384xqQ1aoWXA+058RXPxPg6fy4IWvTNh0E263XmFcJlSAwiGgFAW/dAiS6JXm" crossorigin="anonymous">
    
    
</head>
<body>
  
    <!-- Navigation Bar -->
    <header>
        <nav class="navbar">
            <div class="logo">MyWebsite</div>
            <ul class="nav-links">
                <li><a href={{ path('app_index') }}>Home</a></li>
                <li><a href={{ path('app_about') }}>About</a></li>
                <li><a href={{ path('app_menu') }}>Menu</a></li>
                <li><a href={{ path('app_contact') }}>Contact</a></li>
                {% if app.user %}
                    <li><a href={{ path('app_change_password') }}>Change Password</a></li>
                    <li><a href={{ path('app_user') }}>User</a></li>
                    <li><a href={{ path('app_logout') }}>logout</a></li>
                {% else %}
                    <li><a href={{ path('app_login') }}>login</a></li>
                    <li><a href={{ path('app_register') }}>Register</a></li>
                {% endif %}
            </ul>
        </nav>
    </header>
     

     
     {% block body %} 
        <section id="home" class="section">
            <h1>Welcome to My Website</h1>
            <p>This is the home section. A perfect place for an introduction.</p>
        </section>
    {% endblock %}
  
  
  
   <!-- footer -->
    
    <footer>
        <p>&copy; 2025 MyWebsite. All rights reserved.</p>
    </footer>
    
</body>
</html>
