{% extends 'base.html.twig' %}

{% block title %}
	<title>All Users</title>
{% endblock %}

{% block body %}

	<div class="container mt-5">

		<div class="d-flex justify-content-between align-items-center mb-4">
			<h2 class="fw-bold">All Users</h2>

			<a href="{{ path('user_new') }}" class="btn btn-primary btn-lg shadow-sm px-4">
				New User
			</a>
			
			{# FLASH MESSAGES #}
			{% for type, messages in app.flashes %}
				{% for message in messages %}
					<div class="alert alert-{{ type }} alert-dismissible fade show" role="alert">
						{{ message }}
						<button type="button"></button>
					</div>
				{% endfor %}
			{% endfor %}
		</div>

		<div class="card shadow-lg border-0">
			<div class="card-body p-4">

				<table class="table table-hover table-striped align-middle">
					<thead class="table-dark">
						<tr>
							<th>#</th>
							<th>
								<a href="{{ path('app_user', { page: page, sortBy: 'name', sortDir: sortBy == 'name' and sortDir == 'ASC' ? 'DESC' : 'ASC' }) }}" class="text-white text-decoration-none">
									Name
								</a>
							</th>

							<th>
								<a href="{{ path('app_user', { page: page, sortBy: 'email', sortDir: sortBy == 'email' and sortDir == 'ASC' ? 'DESC' : 'ASC' }) }}" class="text-white text-decoration-none">
									Email
								</a>
							</th>

							<th>Created</th>
							<th>Updated</th>
							<th>Action</th>
						</tr>
					</thead>

					<tbody>
						{% for user in users %}
							<tr>
								<td>{{ user.id }}</td>
								<td class="fw-semibold">{{ user.name }}</td>
								<td>{{ user.email }}</td>

								<td>
									{% if user.created %}
										<span class="badge bg-success">
											{{ user.created|date('Y-m-d H:i') }}
										</span>
									{% else %}
										<span class="text-muted">-</span>
									{% endif %}
								</td>

								<td>
									{% if user.updated %}
										<span class="badge bg-primary">
											{{ user.updated|date('Y-m-d H:i') }}
										</span>
									{% else %}
										<span class="text-muted">-</span>
									{% endif %}
								</td>

								<td class="text-center">

									<a href="{{ path('user_edit', {id: user.id}) }}" class="btn btn-sm btn-warning me-1">
										Edit
									</a>
                                   <a href="{{ path('user_toggle_active', {id: user.id}) }}" class="btn btn-sm {{ user.active ? 'btn-success' : 'btn-secondary' }} me-1">
										{{ user.active ? 'Active' : 'Inactive' }}
									</a>

									<a href="{{ path('user_delete', {id: user.id}) }}" class="btn btn-sm btn-danger" onclick="return confirm('Are you sure?');">
										Delete
									</a>
								</td>

							</tr>
						{% else %}
							<tr>
								<td colspan="5" class="text-center py-4 text-muted">
									No Users Found
								</td>
							</tr>
						{% endfor %}
					</tbody>
				</table>

				{% if totalPages is defined %}
					{% include 'user/custom.html.twig' with {
                        page: page,
                        totalPages: totalPages,
                        sortBy: sortBy,
                        sortDir: sortDir
                    } %}
				{% endif %}


			</div>
		</div>
	</div>
</div>

{% endblock %}
