{% extends 'base.html.twig' %}

{% block title %}
<title>Ring Detail</title>
{% endblock %}

{% block body %}
<div class="container mt-4">
    <h2 class="text-center mb-4">{{ product.name }}</h2>

    <div class="row">
        <div class="col-md-6">
            <img src="/image/ring.jpg" class="img-fluid">
        </div>

        <div class="col-md-6">
            <p><b>Referance:</b> {{ product.referance }}</p>
            <p><b>Price:</b> ₹ {{ product.price }}</p>
            <p><b>Status:</b> {{ product.status ? 'Available' : 'Out of stock' }}</p>
            <p><b>Category:</b> {{ product.category.name }}</p>

            <hr>

            {% if product.ring %}
                <h5>Ring Details</h5>
                <p><b>Size:</b> {{ product.ring.size }}</p>
                <p><b>Stone Type:</b> {{ product.ring.stonetype }}</p>
                <p><b>Style:</b> {{ product.ring.style }}</p>
                <p><b>Weight:</b> {{ product.ring.weight }}</p>
            {% endif %}

            <a href="{{ path('app_ring') }}" class="btn btn-secondary mt-3">Back</a>
        </div>
    </div>
</div>
{% endblock %}